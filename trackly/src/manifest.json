{
  "manifest_version": 3,
  "name": "Trackly - Time Tracker",
  "version": "1.2",
  "description": "Track your time and website usage.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Open Trackly Dashboard"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}